
@{
    ViewBag.Title = "Helper";
}

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background-color: #fafafa;
        }

        .btn {
            background: white;
            border: 2px solid #cb0c9f;
            color: #cb0c9f;
            padding: 14px 32px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: #cb0c9f;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(203, 12, 159, 0.3);
        }

        .input {
            width: 100%;
            padding: 14px 16px 14px 48px;
            border: 2px solid #f0f0f0;
            border-radius: 12px;
            font-size: 15px;
            transition: all 0.2s;
        }


        .content {
            background: white;
            border-radius: 16px;
            max-width: 1000px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            animation: slideUp 0.3s ease;
        }
    </style>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<div class="centercontent1">

    <div class="pageheader">
        <span class="profilepic"><img src="" alt="" /></span>
        <div class="profiletitle">
            <h1 class="pagetitle">Helper</h1>
            <span class="pagedesc"></span>
        </div>
    </div><!--pageheader-->
    <div id="contentwrapper" class="contentwrapper" style="background-color: #fff !important">
        <div>
            <table class="table">

                <tr>
                    <td>
                        <textarea id="txthelper1" rows="5" cols="100" class="input"></textarea><br />
                        <input type="button" id="btn_save1" class="btn btn-primary" value="Help" />
                    </td>
                </tr>
                <tr>
                    <td>
                        <br />
                    </td>
                </tr>
                <tr>
                    <td>
                        <textarea id="txthelper2" rows="5" cols="100" class="input"></textarea><br />
                        <input type="button" id="btn_save2" class="btn btn-primary" value="Help" />
                    </td>
                </tr>
                <tr>
                    <td>
                        <br />
                    </td>
                </tr>
                <tr>
                    <td>
                        <textarea id="txthelper3" rows="5" cols="100" class="input"></textarea><br />
                        <input type="button" id="btn_save3" class="btn btn-primary" value="Help" />
                    </td>
                </tr>
                <tr>
                    <td>
                        <br />
                    </td>
                </tr>
            </table>
            <hr />
            <br />
            <div id="resHepler" class="content">response</div>
        </div>
    </div>
</div>


<script type="text/javascript">

    jQuery(document).ready(function () {
        jQuery("#btn_save1").click(function () {
            var data = {
                message: jQuery('#txthelper1').val()
            };
            console.log(data)
            jQuery.ajax({
                url: '/Home/PostHelpData',
                dataType: "json",
                type: "POST",
                data: JSON.stringify(data),
                contentType: 'application/json; charset=utf-8',
                success: function (response) {
                    var res = JSON.parse(response);
                    console.log(res);

                    jQuery('#resHepler').html('');
                    jQuery('#resHepler').append(res.message);
                },
                error: function (xhr, thrownError, thrownError) {
                    console.log(xhr)
                    console.log(thrownError)
                    console.log(thrownError)
                    var msg = "Message: " + thrownError;
                    jQuery.growl.error({ title: "Exception", message: msg });
                }
            });
        });

