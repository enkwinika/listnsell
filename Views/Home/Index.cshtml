                            ${user.isAdmin ? '<span class="text-[9px] font-black uppercase tracking-widest px-2 py-1 bg-purple-500 text-white rounded-md shadow-sm">Overlord</span>' : ''}
                        </div>
                        <p class="text-xs font-bold text-gray-400 mb-2">${user.email}</p>
                        <div class="flex items-center gap-4 text-[9px] font-black text-gray-400 uppercase tracking-widest">
                            <span class="flex items-center gap-1.5"><i class="fas fa-calendar"></i> Since ${user.joinDate}</span>
                            <span class="flex items-center gap-1.5"><i class="fas fa-tag"></i> ${user.listingsCount} Items</span>
                        </div>
                    </div>
                </div>
                <div class="flex gap-2">
                    <button onclick="viewUserListings(${user.id})" class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-gray-400 hover:text-[#cb0c9f] transition-all" title="View Listings">
                        <i class="fas fa-list-ul"></i>
                    </button>
                    ${!user.isAdmin ? `
                        <button onclick="toggleUserStatus(${user.id}, ${user.isActive})" class="w-10 h-10 rounded-xl ${user.isActive ? 'bg-red-50 text-red-500 hover:bg-red-500 hover:text-white' : 'bg-green-50 text-green-500 hover:bg-green-500 hover:text-white'} flex items-center justify-center transition-all" title="${user.isActive ? 'Suspend' : 'Activate'}">
