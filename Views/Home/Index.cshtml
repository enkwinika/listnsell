    function initPriceSlider() {
        const track = document.getElementById('sliderTrack');
        const range = document.getElementById('sliderRange');
        const minHandle = document.getElementById('minHandle');
        const maxHandle = document.getElementById('maxHandle');
        const minDisplay = document.getElementById('minPriceDisplay');
        const maxDisplay = document.getElementById('maxPriceDisplay');
        const minInput = document.getElementById('minPrice');
        const maxInput = document.getElementById('maxPrice');

        let minPrice = 0;
        let maxPrice = 100000;
        const maxLimit = 100000;

        function updateSlider() {
            const minPercent = (minPrice / maxLimit) * 100;
            const maxPercent = (maxPrice / maxLimit) * 100;

            minHandle.style.left = minPercent + '%';
            maxHandle.style.left = maxPercent + '%';
            range.style.left = minPercent + '%';
            range.style.right = (100 - maxPercent) + '%';

            minDisplay.textContent = minPrice.toLocaleString();
            maxDisplay.textContent = maxPrice === maxLimit ? maxPrice.toLocaleString() : maxPrice.toLocaleString();
            
            minInput.value = minPrice;
            maxInput.value = maxPrice;
        }

        function handleDrag(e, handleType) {
            const rect = track.getBoundingClientRect();
            // Support both mouse and touch events
            const clientX = e.clientX || (e.touches ? e.touches[0].clientX : 0);
            let percent = ((clientX - rect.left) / rect.width) * 100;
            percent = Math.min(Math.max(percent, 0), 100);

            let price = Math.round((percent / 100) * maxLimit);
            // Snap to 500s for larger range
            price = Math.round(price / 500) * 500;

            if (handleType === 'min') {
                if (price < maxPrice - 1000) { // Keep some distance
                    minPrice = price;
                }
            } else {
                if (price > minPrice + 1000) {
                    maxPrice = price;
                }
            }
            updateSlider();
        }

        function startDrag(e, type) {
            const handle = type === 'min' ? minHandle : maxHandle;
            handle.classList.add('active');
            
            const moveHandler = (moveEvent) => {
                // Prevent scrolling while dragging on mobile
                if (moveEvent.type === 'touchmove') moveEvent.preventDefault();
                handleDrag(moveEvent, type);
            };
            
            const upHandler = () => {
                handle.classList.remove('active');
                document.removeEventListener('mousemove', moveHandler);
                document.removeEventListener('mouseup', upHandler);
                document.removeEventListener('touchmove', moveHandler);
                document.removeEventListener('touchend', upHandler);
            };

            document.addEventListener('mousemove', moveHandler);
            document.addEventListener('mouseup', upHandler);
            document.addEventListener('touchmove', moveHandler, { passive: false });
            document.addEventListener('touchend', upHandler);
        }

        minHandle.addEventListener('mousedown', (e) => startDrag(e, 'min'));
        maxHandle.addEventListener('mousedown', (e) => startDrag(e, 'max'));

        // Mobile support
        minHandle.addEventListener('touchstart', (e) => {
            e.preventDefault();
            const touch = e.touches[0];
            startDrag(touch, 'min');
        });
        
        maxHandle.addEventListener('touchstart', (e) => {
            e.preventDefault();
            const touch = e.touches[0];
            startDrag(touch, 'max');
        });

        // Initial update
        updateSlider();

        // Pass back reset function
        window.resetSlider = function() {
            minPrice = 0;
            maxPrice = 100000;
            updateSlider();
        };
    }

    function debounce(func, wait) {
        let timeout;
        return function executedFunction(...args) {
            const later = () => {
                clearTimeout(timeout);
                func(...args);
            };
            clearTimeout(timeout);
            timeout = setTimeout(later, wait);
        };
    }

    function getTimeAgo(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const diffTime = Math.abs(now - date);
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
        
        if (diffDays === 0) return 'Today';
        if (diffDays === 1) return 'Yesterday';
        if (diffDays <= 7) return `${diffDays} days ago`;
        if (diffDays <= 30) return `${Math.floor(diffDays / 7)} weeks ago`;
        return `${Math.floor(diffDays / 30)} months ago`;
    }

