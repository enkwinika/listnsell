// Helper function to parse ASP.NET JSON date format
function parseJsonDate(jsonDate) {
    if (!jsonDate) return null;
    if (typeof jsonDate === 'string' && jsonDate.indexOf('/Date(') === 0) {
        const timestamp = parseInt(jsonDate.substr(6));
        return new Date(timestamp);
    }
    return new Date(jsonDate);
}

function loadSupportTickets() {
    $.ajax({
        url: '@Url.Action("GetSupportTickets", "Home")',
        type: 'GET',
        success: function(response) {
            console.log('Support Tickets Response:', response);
            if (response.code === "1") {
                allTickets = response.tickets;
                console.log('All Tickets:', allTickets);
                if (allTickets && allTickets.length > 0) {
                    console.log('First Ticket:', allTickets[0]);
                }
                renderTickets();
            } else {
                showToast(response.message || 'Failed to load tickets', 'error');
            }
        },
        error: function(xhr, status, error) {
            console.error('Error loading tickets:', error);
            console.error('Response:', xhr.responseText);
            showToast('Error loading support tickets', 'error');
        }
    });
}

function filterTickets(status) {
    currentTicketFilter = status;
    
    document.querySelectorAll('[id^="filter"]').forEach(btn => {
        btn.classList.remove('bg-[#cb0c9f]', 'text-white');
        btn.classList.add('text-gray-400', 'hover:bg-gray-50');
    });
    document.getElementById('filter' + status.charAt(0).toUpperCase() + status.slice(1)).classList.add('bg-[#cb0c9f]', 'text-white');
    document.getElementById('filter' + status.charAt(0).toUpperCase() + status.slice(1)).classList.remove('text-gray-400', 'hover:bg-gray-50');
    
    renderTickets();
}

function renderTickets() {
    const container = document.getElementById('ticketsList');
    const filteredTickets = currentTicketFilter === 'all' 
        ? allTickets 
        : allTickets.filter(t => (t.Status || t.status) === currentTicketFilter);
    
    if (filteredTickets.length === 0) {
        container.innerHTML = `
            <div class="text-center py-16">
                <div class="w-20 h-20 bg-gray-50 rounded-2xl flex items-center justify-center text-gray-300 mx-auto mb-6">
                    <i class="fas fa-inbox text-3xl"></i>
                </div>
                <p class="text-gray-400 font-semibold">No ${currentTicketFilter === 'all' ? '' : currentTicketFilter.toLowerCase()} tickets found</p>
            </div>`;
        return;
    }
    
    container.innerHTML = filteredTickets.map(ticket => {
        const id = ticket.Id || ticket.id;
        const status = ticket.Status || ticket.status || 'Open';
        const title = ticket.Title || ticket.title || 'Untitled';
        const message = ticket.Message || ticket.message || '';
        const userEmail = ticket.UserEmail || ticket.userEmail || 'Unknown';
        const createdAt = ticket.CreatedAt || ticket.createdAt;
        
        const statusColor = status === 'Open' ? 'yellow' : status === 'Responded' ? 'green' : 'gray';
        const parsedDate = parseJsonDate(createdAt);
        const date = parsedDate ? parsedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Unknown';
        
        return `
            <div class="glass-effect p-6 rounded-2xl border border-gray-100 hover:shadow-lg transition-all cursor-pointer" onclick="viewTicketDetail(${id})">
                <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest bg-${statusColor}-50 text-${statusColor}-600">${status}</span>
                            <span class="text-[10px] font-semibold text-gray-400">#${id}</span>
                        </div>
                        <h4 class="text-lg font-black text-gray-900 mb-2">${title}</h4>
                        <p class="text-sm text-gray-600 mb-3 line-clamp-2">${message}</p>
                        <div class="flex items-center gap-4 text-xs text-gray-400 font-semibold">
                            <span><i class="fas fa-user mr-2"></i>${userEmail}</span>
                            <span><i class="fas fa-calendar mr-2"></i>${date}</span>
                        </div>
                    </div>
                    <button class="w-10 h-10 rounded-xl bg-pink-50 flex items-center justify-center text-[#cb0c9f] hover:bg-pink-100 transition-colors">
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>`;
    }).join('');
}

function viewTicketDetail(ticketId) {
    const ticket = allTickets.find(t => (t.Id || t.id) === ticketId);
    if (!ticket) return;
    
    const id = ticket.Id || ticket.id;
    const status = ticket.Status || ticket.status || 'Open';
    const title = ticket.Title || ticket.title || 'Untitled';
    const message = ticket.Message || ticket.message || '';
    const userEmail = ticket.UserEmail || ticket.userEmail || 'Unknown';
    const createdAt = ticket.CreatedAt || ticket.createdAt;
    const adminResponse = ticket.AdminResponse || ticket.adminResponse;
    const respondedAt = ticket.RespondedAt || ticket.respondedAt;
    const respondedBy = ticket.RespondedBy || ticket.respondedBy;
    
    const parsedCreatedAt = parseJsonDate(createdAt);
    const date = parsedCreatedAt ? parsedCreatedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'Unknown';
    const statusColor = status === 'Open' ? 'yellow' : status === 'Responded' ? 'green' : 'gray';
    
    let detailHTML = `
        <div class="space-y-6">
            <div class="flex items-center gap-3">
                <span class="px-4 py-2 rounded-lg text-xs font-black uppercase tracking-widest bg-${statusColor}-50 text-${statusColor}-600">${status}</span>
                <span class="text-sm font-semibold text-gray-400">Ticket #${id}</span>
            </div>
            
            <div>
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Subject</p>
                <h4 class="text-xl font-black text-gray-900">${title}</h4>
            </div>
            
            <div>
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">From</p>
                <p class="text-sm font-semibold text-gray-700">${userEmail}</p>
            </div>
            
            <div>
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Submitted</p>
                <p class="text-sm font-semibold text-gray-700">${date}</p>
            </div>
            
            <div>
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Message</p>
                <div class="bg-gray-50 p-6 rounded-2xl">
                    <p class="text-sm text-gray-700 whitespace-pre-wrap leading-relaxed">${message}</p>
                </div>
            </div>`;
    
    if (adminResponse) {
        const parsedRespondedAt = parseJsonDate(respondedAt);
        const respondedDate = parsedRespondedAt ? parsedRespondedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'Unknown';
        detailHTML += `
            <div>
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Admin Response</p>
                <div class="bg-green-50 border-l-4 border-green-500 p-6 rounded-2xl">
                    <p class="text-sm text-gray-700 whitespace-pre-wrap leading-relaxed mb-3">${adminResponse}</p>
                    <p class="text-xs text-gray-500 font-semibold">Responded by ${respondedBy || 'Admin'} on ${respondedDate}</p>
                </div>
            </div>`;
    }
    
    detailHTML += `</div>`;
    
    document.getElementById('ticketDetailContent').innerHTML = detailHTML;
    document.getElementById('responseTicketId').value = ticketId;
    
    if (status === 'Open') {
        document.getElementById('responseFormSection').classList.remove('hidden');
        document.getElementById('adminResponseMessage').value = '';
    } else {
        document.getElementById('responseFormSection').classList.add('hidden');
    }
    
    document.getElementById('ticketDetailModal').classList.add('active');
}

function submitTicketResponse(event) {
    event.preventDefault();
    
    const ticketId = document.getElementById('responseTicketId').value;
    const responseMessage = document.getElementById('adminResponseMessage').value.trim();
    const submitBtn = document.getElementById('submitResponseBtn');
    
    if (!responseMessage) {
        showToast('Please enter a response message', 'warning');
        return;
    }
    
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
    
    $.ajax({
        url: '@Url.Action("RespondToTicket", "Home")',
        type: 'POST',
        data: {
            ticketId: ticketId,
            responseMessage: responseMessage
        },
        success: function(response) {
            if (response.code === "1") {
                showToast('Response sent successfully! Email sent to user.', 'success');
                closeModal('ticketDetailModal');
                loadSupportTickets();
            } else {
                showToast(response.message || 'Failed to send response', 'error');
            }
        },
        error: function() {
            showToast('An error occurred. Please try again.', 'error');
        },
        complete: function() {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Response & Email User';
        }
    });
}

function loadAdminListings(type) {
    const status = type === 'pending' ? 'Pending' : document.getElementById('adminStatusFilter')?.value || '';
    
    $.ajax({
        url: '/Home/GetAdminListings',
        type: 'GET',
        data: { status: status },
        success: function(response) {
            if (response.code === "1" && response.data) {
                if (type === 'pending') {
                    renderAdminListings(response.data, 'pendingListingsGrid');
                } else {
                    renderAdminListings(response.data, 'allListingsGrid');
                }
            } else {
                showToast(response.message || 'Failed to load listings', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

