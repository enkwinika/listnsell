    function submitListing(event) {
        event.preventDefault();
    
        if (!isLoggedIn) {
            showPage('auth');
            showToast('Please login to create a listing', 'warning');
            return;
        }

        // Validate images
        if (selectedImages.length === 0) {
            showToast('Please upload at least one image', 'warning');
            return;
        }

        const btn = document.getElementById('submitListingBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Uploading images...';

        // Create FormData with images
        const formData = new FormData();
        selectedImages.forEach((file, index) => {
            formData.append('files', file);
        });

        if (selectedImages.length === 0 && isEditing) {
            // No new images, just update data
            createListingWithImages([], btn);
            return;
        }

        // Upload images first
        $.ajax({
            url: '/Home/UploadImages',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            xhr: function() {
                const xhr = new window.XMLHttpRequest();
                // Upload progress
                xhr.upload.addEventListener("progress", function(evt) {
                    if (evt.lengthComputable) {
                        const percentComplete = Math.round((evt.loaded / evt.total) * 100);
                        btn.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i> Uploading... ${percentComplete}%`;
                    }
                }, false);
                return xhr;
            },
            success: function (uploadResponse) {
                if (uploadResponse.code === "1" && uploadResponse.data) {
                    btn.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i> ${isEditing ? 'Updating' : 'Creating'} listing...`;
                    createListingWithImages(uploadResponse.data, btn);
                } else {
                    btn.disabled = false;
                    btn.innerHTML = isEditing ? '<i class="fas fa-save mr-2"></i> Update Listing' : '<i class="fas fa-rocket mr-2"></i> Launch Listing';
                    showToast(uploadResponse.message || 'Failed to upload images', 'error');
                }
            },
            error: function (err) {
                console.error('Upload error:', err);
                btn.disabled = false;
                btn.innerHTML = isEditing ? '<i class="fas fa-save mr-2"></i> Update Listing' : '<i class="fas fa-rocket mr-2"></i> Launch Listing';
                showToast('An error occurred while uploading images', 'error');
            }
        });
    }

    function createListingWithImages(imagePaths, btn) {
        const categoryName = document.getElementById('itemCategory').value;
        const categoryId = getCategoryIdByName(categoryName);

        const listingData = {
            Title: document.getElementById('itemTitle').value,
            Description: document.getElementById('itemDescription').value,
            CategoryId: categoryId,
            Price: parseFloat(document.getElementById('itemPrice').value),
            Condition: document.getElementById('itemCondition').value,
            Location: document.getElementById('itemLocation').value,
            ImagePaths: imagePaths
        };

        const url = isEditing ? `/Home/UpdateListing?id=${editingId}` : '/Home/CreateListing';

        $.ajax({
            url: url,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(listingData),
            success: function(response) {
                btn.disabled = false;
                btn.innerHTML = isEditing ? '<i class="fas fa-save mr-2"></i> Update Listing' : '<i class="fas fa-rocket mr-2"></i> Launch Listing';

                if (response.code === "1") {
                    const msg = isEditing ? 'Your listing has been updated successfully!' : 'Your listing has been submitted successfully!';
                    resetCreateListingForm();
                    showToast(msg, 'success');
                    showPage('dashboard');
                    loadUserListings();
                } else {
                    showToast(response.message || 'Failed to create listing', 'error');
                }
            },
            error: function(err) {
                console.error('Create listing error:', err);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check mr-2"></i> Submit Listing';
                showToast('An error occurred while creating listing', 'error');
            }
        });
    }

