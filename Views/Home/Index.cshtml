<!-- Admin Action Modal (Modernized) -->
<div id="adminActionModal" class="modal">
    <div class="modal-content max-w-2xl animate-in fade-in zoom-in duration-300">
        <button onclick="closeModal('adminActionModal')" class="absolute top-6 right-6 text-gray-400 hover:text-gray-900 transition-colors z-10 w-10 h-10 rounded-full flex items-center justify-center bg-gray-50/50">
            <i class="fas fa-times"></i>
        </button>
        <div id="adminActionModalContent" class="overflow-y-auto max-h-[90vh]"></div>
    </div>
</div>
    <!-- Toast Notification -->
    <div id="toast" class="toast">
        <i id="toastIcon" class="fas fa-check-circle text-green-500 text-xl"></i>
        <span id="toastMessage">Action completed successfully</span>
    </div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // API Base URL
    const API_BASE = '@Url.Content("~/Marketplace/")';
    
    let filteredItems = [];
    let displayedItems = [];
    let itemsToShow = 20;
    let isLoggedIn = false;
    let currentUserName = '';
    let currentItemId = null;
    let userListings = [];
    let selectedCategories = [];
    let selectedConditions = [];
    let currentPage = 1;
    let totalPages = 1;

    function init() {
        checkAuthStatus();
        loadCategories();
        loadInitialItems();
        setupEventListeners();
        initPriceSlider();
    }

    function checkAuthStatus() {
        $.ajax({
            url: '@Url.Action("CheckAuth", "Home")',
            type: 'GET',
            success: function(response) {
                if (response.code === "1" && response.isAuthenticated) {
                    isLoggedIn = true;
                    isAdmin = response.isAdmin || false;
                    currentUserName = (response.data ? response.data.name : response.name) || 'User';
                    updateAuthUI();
                } else {
                    isLoggedIn = false;
                    isAdmin = false;
                    currentUserName = '';
                    updateAuthUI();
                }
            },
            error: function() {
                isLoggedIn = false;
                isAdmin = false;
                currentUserName = '';
                updateAuthUI();
            }
        });
    }

    function loadCategories() {
        $.ajax({
            url: '/Home/GetCategories',
            type: 'GET',
            success: function(response) {
                if (response.code === "1" && response.data) {
                    // Categories are already in HTML, but you could dynamically generate them here
                    console.log('Categories loaded:', response.data);
                }
            }
        });
    }

    function loadInitialItems() {
        applyFilters();
    }

    function applyFilters(isAppend = false) {
        if (!isAppend) currentPage = 1;
        
        const search = document.getElementById('searchInput').value.toLowerCase();
        const location = document.getElementById('locationFilter').value.toLowerCase();
        const minPrice = parseFloat(document.getElementById('minPrice').value) || null;
        const maxPrice = parseFloat(document.getElementById('maxPrice').value) || null;
        const sortBy = document.getElementById('sortBy').value;

        selectedConditions = [];
        document.querySelectorAll('[id^="cond-"]:checked').forEach(cb => {
            selectedConditions.push(cb.value);
        });

        // Get selected category IDs
        const categoryIds = [];
        document.querySelectorAll('[id^="cat-"]:checked:not(#cat-all)').forEach(cb => {
            const categoryName = cb.value;
            if (categoryName) categoryIds.push(getCategoryIdByName(categoryName));
        });

        const filterRequest = {
            SearchTerm: search || null,
            CategoryIds: categoryIds.length > 0 ? categoryIds : null,
            Conditions: selectedConditions.length > 0 ? selectedConditions : null,
            MinPrice: minPrice,
            MaxPrice: maxPrice,
            Location: location || null,
            SortBy: sortBy,
            PageNumber: currentPage,
            PageSize: 20
        };

        $.ajax({
            url: '/Home/GetListings',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(filterRequest),
            success: function(response) {
                if (response.code === "1" && response.data) {
                    const newItems = response.data.items || [];
                    if (isAppend) {
                        filteredItems = filteredItems.concat(newItems);
                    } else {
                        filteredItems = newItems;
                    }
                    displayedItems = filteredItems;
                    totalPages = response.data.totalPages;
                    renderItems(isAppend, newItems);
                    updateLoadMoreButton();
                    document.getElementById('itemCount').textContent = response.data.totalCount;
                    document.getElementById('currentPageNum').textContent = currentPage;
                    document.getElementById('totalPagesNum').textContent = totalPages;
                } else {
                    showToast(response.message || 'Failed to load items', 'error');
                }
            },
            error: function() {
                showToast('An error occurred while loading items', 'error');
            },
            complete: function() {
                // Close mobile filters after applying (only on mobile)
                if (window.innerWidth < 1024) {
                    const sidebar = document.getElementById('filterSidebar');
                    if (sidebar && sidebar.classList.contains('active')) {
                        toggleMobileFilters();
                    }
                }
            }
        });
    }

    function getCategoryIdByName(name) {
        const mapping = {
            'Electronics': 1,
            'Furniture': 2,
            'Clothing': 3,
            'Books': 4,
            'Sports': 5
        };
        return mapping[name] || 0;
    }

    function renderItems(isAppend = false, newItems = []) {
        const grid = document.getElementById('itemsGrid');
        
        const itemsToRender = isAppend ? newItems : displayedItems;

        if (!isAppend && itemsToRender.length === 0) {
            grid.innerHTML = `
                <div class="col-span-full py-20 text-center">
                    <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-search text-gray-300 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-1">No items found</h3>
                    <p class="text-gray-500">Try adjusting your filters or search terms</p>
                </div>
            `;
            return;
        }

        const html = itemsToRender.map(item => `
            <div class="card-premium group" onclick="showItemDetail(${item.id})">
                <div class="relative w-full aspect-[4/3] overflow-hidden rounded-t-[calc(var(--radius-md)-1px)] bg-gray-100">
                    <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    
                    <!-- Floating Price and Badge -->
                    <div class="absolute top-4 left-4 glass-effect px-4 py-2 rounded-xl border border-white/50 shadow-sm">
                        <span class="text-[#cb0c9f] font-black text-lg">R${item.price.toLocaleString()}</span>
                    </div>
                    
                    ${item.isPromoted ? `
                        <div class="absolute top-4 right-4 bg-yellow-400 text-yellow-900 text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-md shadow-sm">
                            Featured
                        </div>
                    ` : ''}
                </div>

                <div class="p-5">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">${item.category}</span>
                        <span class="text-[10px] font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">${item.condition}</span>
                    </div>
                    
                    <h4 class="text-base font-bold text-gray-900 leading-snug mb-4 group-hover:text-[#cb0c9f] transition-colors line-clamp-2 min-h-[2.8rem]">
                        ${item.title}
                    </h4>
                    
                    <div class="flex items-center justify-between pt-4 border-t border-gray-50">
                        <div class="flex items-center gap-2 text-gray-500">
                            <i class="fas fa-map-marker-alt text-[10px]"></i>
                            <span class="text-xs font-semibold">${item.location}</span>
                        </div>
                        <span class="text-[10px] font-bold text-gray-400 uppercase">${getTimeAgo(item.date)}</span>
                    </div>
                </div>
            </div>
        `).join('');
        
        if (isAppend) {
            grid.insertAdjacentHTML('beforeend', html);
        } else {
            grid.innerHTML = html;
        }

        const curPageEl = document.getElementById('currentPageNum');
        const totPageEl = document.getElementById('totalPagesNum');
        if (curPageEl) curPageEl.textContent = currentPage;
        if (totPageEl) totPageEl.textContent = totalPages;
    }

    function showItemDetail(id) {
        // Show something instantly if we can
        const localItem = displayedItems.find(i => i.id === id) || userListings.find(i => i.id === id);
        
        $.ajax({
            url: '@Url.Action("GetListingDetails", "Home")',
            type: 'GET',
            data: { id: id },
            success: function(response) {
                if (response.code === "1" && response.data) {
                    renderItemDetail(response.data);
                } else if (localItem) {
                    renderItemDetail(localItem);
                    showToast('Showing cached details', 'warning');
                } else {
                    showToast(response.message || 'Failed to load item details', 'error');
                }
            },
            error: function() {
                if (localItem) {
                    renderItemDetail(localItem);
                } else {
                    showToast('An error occurred while loading item details', 'error');
                }
            }
        });
    }

    function renderItemDetail(item) {
        currentItemId = item.id;
        const modal = document.getElementById('itemModal');
        const content = document.getElementById('itemModalContent');

        content.innerHTML = `
            <div class="flex flex-col lg:flex-row h-full max-h-[90vh]">
                <!-- Image Side -->
                <div class="w-full lg:w-3/5 bg-white relative flex items-center justify-center overflow-hidden min-h-[400px]">
                    <div class="image-carousel w-full h-full">
                        ${item.images.map((img, idx) => `
                            <img src="${img}" alt="${item.title}" class="carousel-image ${idx === 0 ? 'active' : ''} w-full h-full object-contain" data-index="${idx}">
                        `).join('')}
                    </div>
                    
                    ${item.images.length > 1 ? `
                        <button class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full glass-effect flex items-center justify-center text-gray-900 hover:bg-white transition z-10" onclick="changeCarouselImage(-1)">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <button class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full glass-effect flex items-center justify-center text-gray-900 hover:bg-white transition z-10" onclick="changeCarouselImage(1)">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    ` : ''}
                    
                    <!-- Price Overlay (Mobile Only) -->
                    <div class="lg:hidden absolute bottom-6 left-6 glass-effect px-6 py-3 rounded-2xl border border-white/50 shadow-2xl">
                        <span class="text-3xl font-black text-[#cb0c9f]">R${item.price.toLocaleString()}</span>
                    </div>
                </div>

                <!-- Info Side -->
                <div class="w-full lg:w-2/5 p-8 md:p-12 overflow-y-auto bg-white flex flex-col">
                    <div class="mb-8">
                        <div class="flex items-center gap-2 mb-4">
                            <span class="text-xs font-black text-[#cb0c9f] uppercase tracking-widest bg-pink-50 px-3 py-1 rounded-full">${item.category}</span>
                            <span class="text-xs font-bold text-gray-400">• ${getTimeAgo(item.date)}</span>
                        </div>
                        <h2 class="text-3xl font-black text-gray-900 mb-4 leading-tight">${item.title}</h2>
                        <div class="hidden lg:block">
                            <p class="text-4xl font-black text-[#cb0c9f] mb-8">R${item.price.toLocaleString()}</p>
                        </div>
                    </div>

                    <div class="space-y-8 flex-1">
                        <!-- Seller Info -->
                        <div class="flex items-center gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100">
                            <div class="w-14 h-14 bg-gradient-to-br from-[#cb0c9f] to-[#ff0080] rounded-2xl flex items-center justify-center text-white font-black text-xl shadow-lg shadow-pink-500/30">
                                ${item.seller.name.charAt(0)}
                            </div>
                            <div>
                                <h5 class="font-bold text-gray-900 flex items-center gap-2">
                                    ${item.seller.name}
                                    ${item.seller.verified ? '<i class="fas fa-check-circle text-blue-500 text-xs"></i>' : ''}
                                </h5>
                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Member since ${item.seller.joinDate}</p>
                            </div>
                            <div class="ml-auto">
                                <button onclick="handleInterested(${item.userId}, '${item.seller.name}')" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-400 hover:border-[#cb0c9f] hover:text-[#cb0c9f] transition">
                                    <i class="fas fa-comment-dots"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Details Grid -->
                        <div class="grid grid-cols-2 gap-4">
                            <div class="p-4 rounded-2xl border border-gray-100">
                                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Condition</p>
                                <p class="text-sm font-bold text-gray-900">${item.condition}</p>
                            </div>
                            <div class="p-4 rounded-2xl border border-gray-100">
                                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1">Location</p>
                                <p class="text-sm font-bold text-gray-900">${item.location}</p>
                            </div>
                        </div>

                        <!-- Description -->
                        <div>
                            <h5 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-3">Item Description</h5>
                            <p class="text-gray-600 leading-relaxed text-sm">
                                ${item.description}
                            </p>
                        </div>

                        <!-- Safety Tip -->
                        <div class="p-4 rounded-2xl bg-blue-50 border border-blue-100 flex gap-3">
                            <i class="fas fa-shield-alt text-blue-500 mt-1"></i>
                            <p class="text-[11px] font-semibold text-blue-800 leading-relaxed">
                                Always meet in public places, inspect items carefully, and avoid sharing bank details.
                            </p>
                        </div>

                        ${item.similarItems && item.similarItems.length > 0 ? `
                            <div class="pt-8 border-t border-gray-100">
                                <h5 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6">Similar Inventory</h5>
                                <div class="grid grid-cols-2 gap-4">
                                    ${item.similarItems.map(suggested => `
                                        <div class="group/sitem cursor-pointer" onclick="closeModal('itemModal'); setTimeout(() => showItemDetail(${suggested.id}), 300)">
                                            <div class="aspect-video rounded-xl overflow-hidden bg-gray-100 mb-2">
                                                <img src="${suggested.image}" alt="${suggested.title}" class="w-full h-full object-cover group-hover/sitem:scale-110 transition-transform">
                                            </div>
                                            <h6 class="text-[10px] font-bold text-gray-900 truncate mb-1">${suggested.title}</h6>
                                            <p class="text-xs font-black text-[#cb0c9f]">R${suggested.price.toLocaleString()}</p>
                                        </div>
                                    `).join('')}
                                </div>
                            </div>
                        ` : ''}
                    </div>

                    <!-- Action Buttons -->
                    <div class="mt-12 flex gap-3">
                        <button onclick="handleInterested(${item.userId}, '${item.seller.name}')" class="flex-1 bg-[#cb0c9f] text-white py-4 rounded-2xl font-bold hover:opacity-90 transition-all shadow-xl shadow-pink-500/30 flex items-center justify-center gap-2 active:scale-95 duration-200">
                            <i class="fas fa-comment-dots"></i> Message Seller
                        </button>
                        <button onclick="reportListing(${item.id})" class="w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center text-gray-400 hover:bg-red-50 hover:text-red-500 transition-colors border border-gray-100">
                            <i class="fas fa-flag"></i>
                        </button>
                    </div>
                </div>
            </div>
        `;
        
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function handleInterested(sellerId, name) {
        if (!isLoggedIn) {
            closeModal('itemModal');
            document.getElementById('loginRequiredModal').classList.add('active');
        } else {
            // Store seller ID for message sending
            window.currentSellerId = sellerId;
            document.getElementById('messageRecipient').textContent = name;
            closeModal('itemModal');
            document.getElementById('messageModal').classList.add('active');
        }
    }

    function sendMessage(event) {
        event.preventDefault();
        const messageText = document.getElementById('messageText').value;

        $.ajax({
            url: '/Home/SendMessage',
            type: 'POST',
            data: {
                ListingId: currentItemId,
                ReceiverId: window.currentSellerId,
                MessageText: messageText
            },
            success: function(response) {
                if (response.code === "1") {
                    closeModal('messageModal');
                    showToast('Message sent to seller!', 'success');
                    document.getElementById('messageText').value = '';
                } else {
                    showToast(response.message || 'Failed to send message', 'error');
                }
            },
            error: function() {
                showToast('An error occurred', 'error');
            }
        });
    }

    //function submitListing(event) {
    //    event.preventDefault();
        
    //    if (!isLoggedIn) {
    //        showPage('auth');
    //        showToast('Please login to create a listing', 'warning');
    //        return;
    //    }

    //    const btn = document.getElementById('submitListingBtn');
    //    btn.disabled = true;
    //    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';

