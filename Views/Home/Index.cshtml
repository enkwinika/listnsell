                    <!-- All Listings Content -->
                    <div id="allListingsContent" class="hidden animate-in fade-in duration-500">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8 pb-6 border-b border-gray-100/50">
                            <h3 class="text-xl font-black text-gray-900 uppercase tracking-widest">Global <span class="text-[#cb0c9f]">Archive</span></h3>
                            <div class="flex gap-3">
                                <select id="adminStatusFilter" onchange="loadAdminListings('all')" class="px-6 py-3 bg-gray-50/50 border-gray-100 rounded-xl outline-none text-[11px] font-black uppercase tracking-widest focus:bg-white focus:border-[#cb0c9f]/30 transition-all">
                                    <option value="">All Status</option>
                                    <option value="Pending">Pending</option>
                                    <option value="Approved">Approved</option>
                                    <option value="Rejected">Rejected</option>
                                    <option value="Sold">Sold</option>
