    let selectedImages = [];
    let imageDataTransfer = new DataTransfer();

    function previewImages(event) {
        const files = Array.from(event.target.files);
    
        // Check total count
        if (selectedImages.length + files.length > 5) {
            showToast('Maximum 5 images allowed', 'warning');
            event.target.value = '';
            return;
        }

        // Validate each file
        for (let file of files) {
            if (file.size > 10 * 1024 * 1024) {
                showToast('Each image must be less than 10MB', 'warning');
                event.target.value = '';
                return;
            }
        
            // Check if it's actually an image
            if (!file.type.startsWith('image/')) {
                showToast('Only image files are allowed', 'warning');
                event.target.value = '';
                return;
            }
        }

        // Add new files to selectedImages
        files.forEach(file => {
            if (selectedImages.length < 5) {
                selectedImages.push(file);
                imageDataTransfer.items.add(file);
            }
        });

        // Update the file input
        document.getElementById('imageUpload').files = imageDataTransfer.files;
    
        // Render preview
        renderImagePreviews();
    }

    function renderImagePreviews() {
        const grid = document.getElementById('imagePreviewGrid');
    
        if (selectedImages.length === 0) {
            grid.innerHTML = '';
            return;
        }
    
        grid.innerHTML = selectedImages.map((file, idx) => {
            const url = URL.createObjectURL(file);
            return `
                <div class="relative" style="padding-bottom: 100%; border-radius: 8px; overflow: hidden; border: 2px solid #e5e7eb;">
                    <img src="${url}" class="absolute inset-0 w-full h-full object-cover" alt="Preview ${idx + 1}">
                    <button type="button" 
                            onclick="removeImage(${idx})" 
                            class="absolute top-1 right-1 bg-red-500 hover:bg-red-600 text-white rounded-full w-6 h-6 flex items-center justify-center transition-colors"
                            title="Remove image">
                        <i class="fas fa-times text-xs"></i>
                    </button>
                    <div class="absolute bottom-1 left-1 bg-black bg-opacity-60 text-white text-xs px-2 py-1 rounded">
                        ${idx + 1} of 5
                    </div>
                </div>
            `;
        }).join('');
    }

    function removeImage(index) {
        // Remove from selectedImages array
        selectedImages.splice(index, 1);
    
        // Rebuild DataTransfer
        imageDataTransfer = new DataTransfer();
        selectedImages.forEach(file => {
            imageDataTransfer.items.add(file);
        });
    
        // Update file input
        document.getElementById('imageUpload').files = imageDataTransfer.files;
    
        // Re-render previews
        renderImagePreviews();
    
        showToast(`Image removed. ${selectedImages.length} of 5 images selected`, 'info');
    }

