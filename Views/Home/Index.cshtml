    function submitSupportTicket(event) {
        event.preventDefault();
        
        // Check authentication again
        if (!isLoggedIn) {
            showToast('Please login to submit a support ticket', 'warning');
            closeModal('contactModal');
            showPage('auth');
            return;
        }
        
        const title = document.getElementById('supportTitle').value.trim();
        const message = document.getElementById('supportMessage').value.trim();
        const submitBtn = document.getElementById('submitSupportBtn');
        
        // Validation
        if (!title || !message) {
            showToast('Please fill in all fields', 'warning');
            return;
        }
        
        if (title.length > 200) {
            showToast('Subject must be 200 characters or less', 'warning');
            return;
        }
        
        if (message.length > 2000) {
            showToast('Message must be 2000 characters or less', 'warning');
            return;
        }
        
        // Disable button and show loading state
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
        
        $.ajax({
            url: '@Url.Action("SubmitSupportTicket", "Home")',
            type: 'POST',
            data: {
                title: title,
                message: message
            },
            success: function(response) {
                if (response.code === "1") {
                    showToast('Support ticket submitted successfully! We\'ll respond within 24 hours.', 'success');
                    closeModal('contactModal');
                    document.getElementById('contactForm').reset();
                } else {
                    showToast(response.message || 'Failed to submit support ticket', 'error');
                }
            },
            error: function() {
                showToast('An error occurred. Please try again later.', 'error');
            },
            complete: function() {
                // Re-enable button
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Send Support Ticket';
            }
        });
    }


