    function checkAuthStatus() {
        $.ajax({
            url: '@Url.Action("CheckAuth", "Home")',
            type: 'GET',
            success: function(response) {
                if (response.code === "1" && response.isAuthenticated) {
                    isLoggedIn = true;
                    updateAuthUI();
                }
            }
        });
    }

    function loadCategories() {
        $.ajax({
            url: '/Home/GetCategories',
            type: 'GET',
            success: function(response) {
                if (response.code === "1" && response.data) {
                    // Categories are already in HTML, but you could dynamically generate them here
                    console.log('Categories loaded:', response.data);
                }
            }
        });
    }

    function loadInitialItems() {
        applyFilters();
    }

    function applyFilters() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const location = document.getElementById('locationFilter').value.toLowerCase();
        const minPrice = parseFloat(document.getElementById('minPrice').value) || null;
        const maxPrice = parseFloat(document.getElementById('maxPrice').value) || null;
        const sortBy = document.getElementById('sortBy').value;

        selectedConditions = [];
        document.querySelectorAll('[id^="cond-"]:checked').forEach(cb => {
            selectedConditions.push(cb.value);
        });

        // Get selected category IDs
        const categoryIds = [];
        document.querySelectorAll('[id^="cat-"]:checked:not(#cat-all)').forEach(cb => {
            const categoryName = cb.value;
            // Map category name to ID (you'd need to store this mapping)
            if (categoryName) categoryIds.push(getCategoryIdByName(categoryName));
        });

        const filterRequest = {
            SearchTerm: search || null,
            CategoryIds: categoryIds.length > 0 ? categoryIds : null,
            Conditions: selectedConditions.length > 0 ? selectedConditions : null,
            MinPrice: minPrice,
            MaxPrice: maxPrice,
            Location: location || null,
            SortBy: sortBy,
            PageNumber: currentPage,
            PageSize: 20
        };

        $.ajax({
            url: '/Home/GetListings',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(filterRequest),
            success: function(response) {
                if (response.code === "1" && response.data) {
                    filteredItems = response.data.items || [];
                    displayedItems = filteredItems;
                    totalPages = response.data.totalPages;
                    renderItems();
                    updateLoadMoreButton();
                    document.getElementById('itemCount').textContent = response.data.totalCount;
                } else {
                    showToast(response.message || 'Failed to load items', 'error');
                }
            },
            error: function() {
                showToast('An error occurred while loading items', 'error');
            }
        });
    }

    function getCategoryIdByName(name) {
        const mapping = {
            'Electronics': 1,
            'Furniture': 2,
            'Clothing': 3,
            'Books': 4,
            'Sports': 5
        };
        return mapping[name] || 0;
    }

    function renderItems() {
        const grid = document.getElementById('itemsGrid');
        
        if (displayedItems.length === 0) {
            grid.innerHTML = '<div class="col-span-full text-center py-12"><p class="text-gray-500 text-lg">No items found</p></div>';
            return;
