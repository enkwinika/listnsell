    grid.innerHTML = listings.map(item => `
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition">
            <div class="item-image-wrapper">
                <img src="${item.image}" alt="${item.title}" class="item-image">
                <div class="absolute top-2 right-2">
                    <span class="text-xs px-3 py-1 rounded-full ${
                        item.status === 'Pending' ? 'bg-yellow-100 text-yellow-800' : 
                        item.status === 'Sold' ? 'bg-gray-100 text-gray-800' : 
                        item.status === 'Approved' ? 'bg-green-100 text-green-800' :
                        'bg-red-100 text-red-800'
                    } font-semibold">${item.status}</span>
                </div>
            </div>
            <div class="p-4">
                <h3 class="font-bold text-lg mb-2 truncate">${item.title}</h3>
                <p class="text-xl font-bold brand-color mb-2">R${item.price.toLocaleString()}</p>
                <div class="text-sm text-gray-600 mb-3">
                    <p><i class="fas fa-user mr-1"></i> ${item.seller || 'Unknown'}</p>
                    <p><i class="fas fa-map-marker-alt mr-1"></i> ${item.location}</p>
                    <p><i class="fas fa-clock mr-1"></i> ${getTimeAgo(item.date)}</p>
                </div>
                <div class="flex gap-2">
                    <button onclick="viewListingDetails(${item.id})" class="flex-1 bg-blue-50 text-blue-600 py-2 rounded-lg hover:bg-blue-100 transition text-sm font-medium">
                        <i class="fas fa-eye"></i> View
                    </button>
                    ${item.status === 'Pending' ? `
                        <button onclick="approveListingAdmin(${item.id})" class="flex-1 bg-green-50 text-green-600 py-2 rounded-lg hover:bg-green-100 transition text-sm font-medium">
                            <i class="fas fa-check"></i> Approve
                        </button>
                        <button onclick="rejectListingAdmin(${item.id})" class="flex-1 bg-red-50 text-red-600 py-2 rounded-lg hover:bg-red-100 transition text-sm font-medium">
                            <i class="fas fa-times"></i> Reject
                        </button>
                    ` : `
                        <button onclick="deleteListingAdmin(${item.id})" class="flex-1 bg-red-50 text-red-600 py-2 rounded-lg hover:bg-red-100 transition text-sm font-medium">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    `}
                </div>
            </div>
        </div>
    `).join('');
}

function viewListingDetails(listingId) {
    showItemDetail(listingId);
}

function approveListingAdmin(listingId) {
    if (!confirm('Approve this listing?')) return;

    $.ajax({
        url: '/Home/ApproveListing',
        type: 'POST',
        data: { id: listingId },
        success: function(response) {
            if (response.code === "1") {
                showToast('Listing approved successfully', 'success');
                loadAdminStats();
                loadAdminListings('pending');
            } else {
                showToast(response.message || 'Failed to approve listing', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function rejectListingAdmin(listingId) {
    const reason = prompt('Please provide a reason for rejection:');
    if (!reason || reason.trim() === '') return;

    $.ajax({
        url: '/Home/RejectListing',
        type: 'POST',
        data: { 
            id: listingId,
            reason: reason 
        },
        success: function(response) {
            if (response.code === "1") {
                showToast('Listing rejected', 'success');
                loadAdminStats();
                loadAdminListings('pending');
            } else {
                showToast(response.message || 'Failed to reject listing', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function deleteListingAdmin(listingId) {
    if (!confirm('Are you sure you want to permanently delete this listing? This action cannot be undone.')) {
        return;
    }

    $.ajax({
        url: '/Home/AdminDeleteListing',
        type: 'POST',
        data: { id: listingId },
        success: function(response) {
            if (response.code === "1") {
                showToast('Listing deleted successfully', 'success');
                loadAdminStats();
                switchAdminTab('all'); // Reload current tab
            } else {
                showToast(response.message || 'Failed to delete listing', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function loadReportedListings() {
    $.ajax({
        url: '/Home/GetReportedListings',
        type: 'GET',
        success: function(response) {
            if (response.code === "1" && response.data) {
                renderReportedListings(response.data);
            } else {
                showToast(response.message || 'Failed to load reported listings', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function renderReportedListings(reports) {
    const grid = document.getElementById('reportedListingsGrid');
    
    if (reports.length === 0) {
        grid.innerHTML = '<p class="text-gray-500 text-center py-8">No reported listings</p>';
        return;
    }

    grid.innerHTML = reports.map(report => `
        <div class="bg-white border border-red-200 rounded-xl p-5 hover:shadow-lg transition">
            <div class="flex gap-4">
                <img src="${report.listingImage}" alt="${report.listingTitle}" class="w-24 h-24 object-cover rounded-lg">
                <div class="flex-1">
                    <div class="flex justify-between items-start mb-2">
                        <h4 class="font-bold text-lg">${report.listingTitle}</h4>
                        <span class="text-xs px-3 py-1 rounded-full bg-red-100 text-red-800 font-semibold">
                            ${report.reportCount} Report${report.reportCount > 1 ? 's' : ''}
                        </span>
                    </div>
                    <p class="text-sm text-gray-600 mb-3">
                        <i class="fas fa-user mr-1"></i> Seller: ${report.sellerName}
                    </p>
                    <div class="bg-red-50 rounded-lg p-3 mb-3">
                        <p class="text-sm text-red-800"><strong>Latest Report:</strong></p>
                        <p class="text-sm text-red-700">"${report.latestReason}"</p>
                        <p class="text-xs text-red-600 mt-1">Reported by: ${report.reporterName} - ${getTimeAgo(report.reportDate)}</p>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="viewListingDetails(${report.listingId})" class="bg-blue-50 text-blue-600 px-4 py-2 rounded-lg hover:bg-blue-100 transition text-sm font-medium">
                            <i class="fas fa-eye mr-1"></i> View Listing
                        </button>
                        <button onclick="dismissReport(${report.reportId})" class="bg-gray-100 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200 transition text-sm font-medium">
                            <i class="fas fa-check mr-1"></i> Dismiss
                        </button>
                        <button onclick="deleteListingAdmin(${report.listingId})" class="bg-red-50 text-red-600 px-4 py-2 rounded-lg hover:bg-red-100 transition text-sm font-medium">
                            <i class="fas fa-trash mr-1"></i> Delete Listing
                        </button>
                    </div>
                </div>
            </div>
        </div>
    `).join('');
}

function dismissReport(reportId) {
    $.ajax({
        url: '/Home/DismissReport',
        type: 'POST',
        data: { id: reportId },
        success: function(response) {
            if (response.code === "1") {
                showToast('Report dismissed', 'success');
                loadReportedListings();
                loadAdminStats();
            } else {
                showToast(response.message || 'Failed to dismiss report', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function loadAllUsers() {
    $.ajax({
        url: '/Home/GetAllUsers',
        type: 'GET',
        success: function(response) {
            if (response.code === "1" && response.data) {
                renderUsers(response.data);
            } else {
                showToast(response.message || 'Failed to load users', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function renderUsers(users) {
    const grid = document.getElementById('usersGrid');
    
    if (users.length === 0) {
        grid.innerHTML = '<p class="text-gray-500 text-center py-8">No users found</p>';
        return;
    }

    grid.innerHTML = users.map(user => `
        <div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-purple-600 rounded-full flex items-center justify-center text-white font-bold text-lg">
                        ${user.name.charAt(0)}
                    </div>
                    <div>
                        <p class="font-semibold text-gray-800 flex items-center gap-2">
                            ${user.name}
                            ${user.isAdmin ? '<span class="text-xs px-2 py-1 bg-purple-100 text-purple-700 rounded-full font-semibold">Admin</span>' : ''}
                        </p>
                        <p class="text-sm text-gray-600">${user.email}</p>
                        <p class="text-xs text-gray-500">Joined: ${user.joinDate} • ${user.listingsCount} listings</p>
                    </div>
                </div>
                <div class="flex gap-2">
                    <button onclick="viewUserListings(${user.id})" class="bg-blue-50 text-blue-600 px-3 py-2 rounded-lg hover:bg-blue-100 transition text-sm">
                        <i class="fas fa-list"></i> Listings
                    </button>
                    ${!user.isAdmin ? `
                        <button onclick="toggleUserStatus(${user.id}, ${user.isActive})" class="bg-${user.isActive ? 'red' : 'green'}-50 text-${user.isActive ? 'red' : 'green'}-600 px-3 py-2 rounded-lg hover:bg-${user.isActive ? 'red' : 'green'}-100 transition text-sm">
                            <i class="fas fa-${user.isActive ? 'ban' : 'check'}"></i> ${user.isActive ? 'Suspend' : 'Activate'}
                        </button>
                    ` : ''}
                </div>
            </div>
        </div>
    `).join('');
}

function viewUserListings(userId) {
    showToast('View user listings functionality', 'info');
    // You can implement this to filter listings by user
}

function toggleUserStatus(userId, currentStatus) {
    const action = currentStatus ? 'suspend' : 'activate';
    if (!confirm(`Are you sure you want to ${action} this user?`)) return;

    $.ajax({
        url: '/Home/ToggleUserStatus',
        type: 'POST',
        data: { 
            userId: userId,
            isActive: !currentStatus 
        },
        success: function(response) {
            if (response.code === "1") {
                showToast(`User ${action}d successfully`, 'success');
                loadAllUsers();
            } else {
                showToast(response.message || `Failed to ${action} user`, 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

// Update document click handler for admin menu
document.addEventListener('click', function(event) {
    const userMenu = document.getElementById('userMenu');
    const adminMenu = document.getElementById('adminMenu');
    const userMenuBtn = document.getElementById('userMenuBtn');
    
    if (userMenu && userMenuBtn && !userMenu.contains(event.target) && !userMenuBtn.contains(event.target)) {
        userMenu.classList.add('hidden');
    }
    
    if (adminMenu && userMenuBtn && !adminMenu.contains(event.target) && !userMenuBtn.contains(event.target)) {
        adminMenu.classList.add('hidden');
    }
});

    // Initialize on page load
    init();
</script>
