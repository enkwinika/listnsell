                                <button onclick="loadAdminListings('all')" class="w-12 h-12 rounded-xl bg-gray-50 flex items-center justify-center text-gray-400 hover:text-[#cb0c9f] transition-colors">
                                    <i class="fas fa-sync-alt text-xs"></i>
