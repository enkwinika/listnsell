    }

    grid.innerHTML = listings.map(item => `
        <div class="glass-effect rounded-3xl border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300">
            <div class="relative w-full aspect-video bg-gray-100">
                <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover">
                <div class="absolute top-4 left-4">
                    <span class="text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-lg shadow-sm ${
                        item.status === 'Pending' ? 'bg-yellow-400 text-yellow-900' : 
                        item.status === 'Sold' ? 'bg-gray-900 text-white' : 
                        item.status === 'Approved' ? 'bg-green-500 text-white' :
                        'bg-red-500 text-white'
                    }">${item.status}</span>
                </div>
            </div>
            <div class="p-6">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <h4 class="font-black text-gray-900 text-base truncate mb-1">${item.title}</h4>
                        <p class="text-sm font-black text-[#cb0c9f]">R${item.price.toLocaleString()}</p>
                    </div>
                    <div class="text-[10px] font-black text-gray-400 uppercase tracking-widest text-right">
                        <p>${getTimeAgo(item.date)}</p>
                    </div>
                </div>
                
                <div class="space-y-2 mb-6 text-[11px] font-bold text-gray-500">
                    <p class="flex items-center gap-2"><i class="fas fa-user text-[#cb0c9f]/50"></i> ${item.seller || 'Anonymous'}</p>
                    <p class="flex items-center gap-2"><i class="fas fa-map-marker-alt text-[#cb0c9f]/50"></i> ${item.location}</p>
                </div>

                <div class="flex gap-2">
                    <button onclick="viewListingDetails(${item.id})" class="flex-1 bg-gray-900 text-white py-3 rounded-xl hover:bg-black transition text-[10px] font-black uppercase tracking-widest">
                        Preview
                    </button>
                    ${item.status === 'Pending' ? `
                        <button onclick="approveListingAdmin(${item.id})" class="flex-1 bg-green-500 text-white py-3 rounded-xl hover:opacity-90 transition text-[10px] font-black uppercase tracking-widest">
                            Approve
                        </button>
                        <button onclick="rejectListingAdmin(${item.id})" class="flex-1 bg-red-500 text-white py-3 rounded-xl hover:opacity-90 transition text-[10px] font-black uppercase tracking-widest">
                            Reject
                        </button>
                    ` : `
                        <button onclick="deleteListingAdmin(${item.id})" class="flex-1 bg-red-50 text-red-600 py-3 rounded-xl hover:bg-red-100 transition text-[10px] font-black uppercase tracking-widest">
                            Purge
                        </button>
                    `}
                </div>
            </div>
        </div>
    `).join('');
}

function viewListingDetails(listingId) {
    showItemDetail(listingId);
}

function approveListingAdmin(listingId) {
    if (!confirm('Approve this listing?')) return;

    $.ajax({
        url: '/Home/ApproveListing',
        type: 'POST',
        data: { id: listingId },
        success: function(response) {
            if (response.code === "1") {
                showToast('Listing approved successfully', 'success');
                loadAdminStats();
                loadAdminListings('pending');
            } else {
                showToast(response.message || 'Failed to approve listing', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function rejectListingAdmin(listingId) {
    const reason = prompt('Please provide a reason for rejection:');
    if (!reason || reason.trim() === '') return;

    $.ajax({
        url: '/Home/RejectListing',
        type: 'POST',
        data: { 
            id: listingId,
            reason: reason 
        },
        success: function(response) {
            if (response.code === "1") {
                showToast('Listing rejected', 'success');
                loadAdminStats();
                loadAdminListings('pending');
            } else {
                showToast(response.message || 'Failed to reject listing', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function deleteListingAdmin(listingId) {
    if (!confirm('Are you sure you want to permanently delete this listing? This action cannot be undone.')) {
        return;
    }

    $.ajax({
        url: '/Home/AdminDeleteListing',
        type: 'POST',
        data: { id: listingId },
        success: function(response) {
            if (response.code === "1") {
                showToast('Listing deleted successfully', 'success');
                loadAdminStats();
                switchAdminTab('all'); // Reload current tab
            } else {
                showToast(response.message || 'Failed to delete listing', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

function loadReportedListings() {
    $.ajax({
        url: '/Home/GetReportedListings',
        type: 'GET',
        success: function(response) {
            if (response.code === "1" && response.data) {
                renderReportedListings(response.data);
            } else {
                showToast(response.message || 'Failed to load reported listings', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

