    function handleCategoryFilter(checkbox) {
        if (checkbox.value === '') {
            document.querySelectorAll('[id^="cat-"]').forEach(cb => {
                if (cb.id !== 'cat-all') cb.checked = false;
            });
            selectedCategories = [];
        } else {
            document.getElementById('cat-all').checked = false;
            if (checkbox.checked) {
                selectedCategories.push(checkbox.value);
            } else {
                selectedCategories = selectedCategories.filter(c => c !== checkbox.value);
            }
            
            if (selectedCategories.length === 0) {
                document.getElementById('cat-all').checked = true;
            }
        }
        currentPage = 1;
        applyFilters();
    }

