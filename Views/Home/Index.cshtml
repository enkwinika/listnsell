function loadAdminListings(type) {
    const status = type === 'pending' ? 'Pending' : document.getElementById('adminStatusFilter')?.value || '';
    
    $.ajax({
        url: '/Home/GetAdminListings',
        type: 'GET',
        data: { status: status },
        success: function(response) {
            if (response.code === "1" && response.data) {
                if (type === 'pending') {
                    renderAdminListings(response.data, 'pendingListingsGrid');
                } else {
                    renderAdminListings(response.data, 'allListingsGrid');
                }
            } else {
                showToast(response.message || 'Failed to load listings', 'error');
            }
        },
        error: function() {
            showToast('An error occurred', 'error');
        }
    });
}

