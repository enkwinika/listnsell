    function submitListing(event) {
        event.preventDefault();
    
        if (!isLoggedIn) {
            showPage('auth');
            showToast('Please login to create a listing', 'warning');
            return;
        }

        // Validate images
        if (selectedImages.length === 0) {
            showToast('Please upload at least one image', 'warning');
            return;
        }

        const btn = document.getElementById('submitListingBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Uploading images...';

        // Create FormData with images
        const formData = new FormData();
        selectedImages.forEach((file, index) => {
            formData.append('files', file);
        });

        // Upload images first
        $.ajax({
            url: '/Home/UploadImages',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            xhr: function() {
                const xhr = new window.XMLHttpRequest();
                // Upload progress
                xhr.upload.addEventListener("progress", function(evt) {
                    if (evt.lengthComputable) {
                        const percentComplete = Math.round((evt.loaded / evt.total) * 100);
                        btn.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i> Uploading... ${percentComplete}%`;
                    }
                }, false);
                return xhr;
            },
            success: function (uploadResponse) {
                if (uploadResponse.code === "1" && uploadResponse.data) {
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Creating listing...';
                    createListingWithImages(uploadResponse.data, btn);
                } else {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-check mr-2"></i> Submit Listing';
                    showToast(uploadResponse.message || 'Failed to upload images', 'error');
                }
            },
            error: function (err) {
                console.error('Upload error:', err);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check mr-2"></i> Submit Listing';
                showToast('An error occurred while uploading images', 'error');
            }
        });
    }

    function createListingWithImages(imagePaths, btn) {
        const categoryName = document.getElementById('itemCategory').value;
        const categoryId = getCategoryIdByName(categoryName);

        const listingData = {
            Title: document.getElementById('itemTitle').value,
            Description: document.getElementById('itemDescription').value,
            CategoryId: categoryId,
            Price: parseFloat(document.getElementById('itemPrice').value),
            Condition: document.getElementById('itemCondition').value,
            Location: document.getElementById('itemLocation').value,
            ImagePaths: imagePaths
        };

        $.ajax({
            url: '/Home/CreateListing',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(listingData),
            success: function(response) {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check mr-2"></i> Submit Listing';

                if (response.code === "1") {
                    resetCreateListingForm();
                    showToast('Your listing has been submitted successfully!', 'success');
                    showPage('dashboard');
                    loadUserListings();
                } else {
                    showToast(response.message || 'Failed to create listing', 'error');
                }
            },
            error: function(err) {
                console.error('Create listing error:', err);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check mr-2"></i> Submit Listing';
                showToast('An error occurred while creating listing', 'error');
            }
        });
    }

    function loadUserListings() {
        $.ajax({
            url: '/Home/GetMyListings',
            type: 'GET',
            success: function(response) {
                if (response.code === "1" && response.data) {
                    userListings = response.data;
                    renderUserListings();
                } else {
                    showToast(response.message || 'Failed to load your listings', 'error');
                }
            },
            error: function() {
                showToast('An error occurred', 'error');
            }
        });
    }

    function renderUserListings() {
        const grid = document.getElementById('myListingsGrid');
        
        if (userListings.length === 0) {
            grid.innerHTML = '<p class="text-gray-500 col-span-full text-center py-8">No listings yet. <a href="#" onclick="showPage(\'create\')" class="brand-color hover:underline font-semibold">Create your first listing</a></p>';
            return;
        }

        grid.innerHTML = userListings.map(item => `
            <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
                <div class="item-image-wrapper">
                    <img src="${item.image}" alt="${item.title}" class="item-image">
                </div>
                <div class="p-4">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-bold text-lg truncate flex-1">${item.title}</h3>
                        <span class="text-xs px-3 py-1 rounded-full ${
                            item.status === 'Pending' ? 'bg-yellow-100 text-yellow-800' : 
                            item.status === 'Sold' ? 'bg-gray-100 text-gray-800' : 
                            item.status === 'Approved' ? 'bg-green-100 text-green-800' :
                            'bg-red-100 text-red-800'
                        } font-semibold ml-2">${item.status}</span>
                    </div>
                    <p class="text-xl font-bold brand-color mb-2">R${item.price.toLocaleString()}</p>
                    <p class="text-xs text-gray-500 mb-3">
                        <i class="fas fa-eye mr-1"></i> ${item.viewCount} views
                    </p>
                    <div class="flex gap-2">
                        <button onclick="editListing(${item.id})" class="flex-1 bg-gray-100 text-gray-700 py-2 rounded-lg hover:bg-gray-200 transition text-sm font-medium">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                        <button onclick="deleteListing(${item.id})" class="flex-1 bg-red-50 text-red-600 py-2 rounded-lg hover:bg-red-100 transition text-sm font-medium">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                        ${item.status !== 'Sold' ? `
                        <button onclick="markAsSold(${item.id})" class="flex-1 bg-green-50 text-green-600 py-2 rounded-lg hover:bg-green-100 transition text-sm font-medium">
                            <i class="fas fa-check"></i> Sold
                        </button>
                        ` : ''}
                    </div>
                </div>
            </div>
        `).join('');
    }

    function deleteListing(id) {
        if (!confirm('Are you sure you want to delete this listing?')) {
            return;
        }

        $.ajax({
            url: '/Home/DeleteListing',
            type: 'POST',
            data: { id: id },
            success: function(response) {
                if (response.code === "1") {
                    showToast('Listing deleted successfully', 'success');
                    loadUserListings();
                } else {
                    showToast(response.message || 'Failed to delete listing', 'error');
                }
            },
            error: function() {
                showToast('An error occurred', 'error');
            }
        });
    }

    function markAsSold(id) {
        $.ajax({
            url: '/Home/MarkAsSold',
            type: 'POST',
            data: { id: id },
            success: function(response) {
                if (response.code === "1") {
                    showToast('Marked as sold!', 'success');
                    loadUserListings();
                } else {
                    showToast(response.message || 'Failed to mark as sold', 'error');
                }
            },
            error: function() {
                showToast('An error occurred', 'error');
            }
        });
    }

