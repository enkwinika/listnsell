@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - listNsell</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-effect {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
    </style>
</head>
<body class="bg-[#f8f9fa] min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md w-full">
        <div class="glass-effect rounded-[30px] shadow-2xl overflow-hidden border-0">
            <!-- Header Icon -->
            <div class="pt-12 pb-6 text-center">
                @if (ViewBag.Success == true)
                {
                    <div class="w-24 h-24 bg-green-50 rounded-full mx-auto flex items-center justify-center mb-6">
                        <i class="fas fa-check-circle text-green-500 text-5xl"></i>
                    </div>
                }
                else
                {
                    <div class="w-24 h-24 bg-red-50 rounded-full mx-auto flex items-center justify-center mb-6">
                        <i class="fas fa-exclamation-circle text-red-500 text-5xl"></i>
                    </div>
                }
                <h1 class="text-3xl font-extrabold text-gray-900 px-6">@ViewBag.Title</h1>
            </div>

            <!-- Content -->
            <div class="p-8 pt-0">
                <p class="text-gray-500 text-center text-lg leading-relaxed mb-10">
                    @ViewBag.Message
                </p>

                <div class="space-y-4">
                    @if (ViewBag.Success == true)
                    {
                        <a href="/" class="w-full h-[60px] flex items-center justify-center bg-gradient-to-r from-[#cb0c9f] to-[#7928ca] text-white font-bold rounded-2xl hover:shadow-lg hover:scale-[1.02] transition-all duration-300">
                            Go to Homepage
                        </a>
                        <p class="text-center text-sm text-gray-400">
                            Redirecting in <span id="timer" class="font-bold text-[#cb0c9f]">5</span> seconds...
                        </p>
                    }
                    else
                    {
                        <a href="/" class="w-full h-[60px] flex items-center justify-center bg-gray-900 text-white font-bold rounded-2xl hover:shadow-lg hover:scale-[1.02] transition-all duration-300">
                            Return to Homepage
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Footer Logo -->
        <div class="mt-8 text-center">
            <div class="flex items-center justify-center gap-2 mb-2">
                <div class="w-8 h-8 bg-gradient-to-tr from-[#cb0c9f] to-[#7928ca] rounded-lg flex items-center justify-center">
                    <span class="text-white font-black text-xs">LN</span>
                </div>
                <span class="text-xl font-black tracking-tighter text-gray-900">listNsell</span>
            </div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Buy & Sell with Confidence</p>
        </div>
    </div>

    @if (ViewBag.Success == true)
    {
        <script>
            let seconds = 5;
            const timer = document.getElementById('timer');
            const interval = setInterval(() => {
                seconds--;
                timer.innerText = seconds;
                if (seconds <= 0) {
                    clearInterval(interval);
                    window.location.href = '/';
                }
            }, 1000);
        </script>
    }
</body>
</html>
