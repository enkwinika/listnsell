@* Enhanced Messaging Interface *@
@{
    ViewBag.Title = "Messages - ReXell Marketplace";
}

<style>
    .messages-page {
        height: calc(100vh - 80px);
        background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%);
        padding: 2rem;
    }

    .messages-container {
        max-width: 1400px;
        margin: 0 auto;
        height: 100%;
        background: white;
        border-radius: 24px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        display: grid;
        grid-template-columns: 380px 1fr;
    }

    /* Conversations List */
    .conversations-panel {
        border-right: 1px solid #f3f4f6;
        display: flex;
        flex-direction: column;
    }

    .conversations-header {
        padding: 2rem;
        border-bottom: 1px solid #f3f4f6;
    }

    .conversations-title {
        font-size: 24px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 1rem;
    }

    .conversations-search {
        position: relative;
    }

    .conversations-search input {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 3rem;
        border: 2px solid #f3f4f6;
        border-radius: 12px;
        font-size: 14px;
        transition: all 0.3s;
    }

    .conversations-search input:focus {
        outline: none;
        border-color: #cb0c9f;
        background: #fef5fb;
    }

    .conversations-search i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
    }

    .conversations-list {
        flex: 1;
        overflow-y: auto;
    }

    .conversation-item {
        padding: 1.25rem;
        border-bottom: 1px solid #f3f4f6;
        cursor: pointer;
        transition: all 0.3s;
        position: relative;
    }

    .conversation-item:hover {
        background: #f9fafb;
    }

    .conversation-item.active {
        background: linear-gradient(90deg, rgba(203, 12, 159, 0.1) 0%, transparent 100%);
        border-left: 4px solid #cb0c9f;
    }

    .conversation-item.unread {
        background: rgba(203, 12, 159, 0.05);
    }

    .conversation-item.unread::after {
        content: '';
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        width: 10px;
        height: 10px;
        background: #ef4444;
        border-radius: 50%;
    }

    .conversation-header {
        display: flex;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .conversation-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, #cb0c9f, #b00a88);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        flex-shrink: 0;
    }

    .conversation-info {
        flex: 1;
        min-width: 0;
    }

    .conversation-name {
        font-weight: 600;
        color: #1f2937;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.25rem;
    }

    .conversation-time {
        font-size: 12px;
        color: #9ca3af;
    }

    .conversation-preview {
        font-size: 14px;
        color: #6b7280;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .conversation-item.unread .conversation-preview {
        font-weight: 600;
        color: #1f2937;
    }

    .listing-badge {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding: 0.5rem;
        background: #f9fafb;
        border-radius: 8px;
        font-size: 12px;
    }

    .listing-badge img {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        object-fit: cover;
    }

    .listing-badge-info {
        flex: 1;
        min-width: 0;
    }

    .listing-badge-title {
        font-weight: 600;
        color: #374151;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .listing-badge-price {
        color: #cb0c9f;
        font-weight: 700;
        font-size: 13px;
    }

    /* Chat Panel */
    .chat-panel {
        display: flex;
        flex-direction: column;
        background: #fafafa;
    }

    .chat-header {
        padding: 1.5rem 2rem;
        background: white;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-user-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .chat-user-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, #cb0c9f, #b00a88);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
    }

    .chat-user-details h3 {
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 0.25rem;
    }

    .chat-user-status {
        font-size: 13px;
        color: #22c55e;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background: #22c55e;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .chat-actions {
        display: flex;
        gap: 0.75rem;
    }

    .chat-action-btn {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: none;
        background: #f3f4f6;
        color: #6b7280;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chat-action-btn:hover {
        background: #e5e7eb;
        color: #374151;
    }

    /* Messages Area */
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .message-group {
        display: flex;
        gap: 0.75rem;
        align-items: flex-end;
    }

    .message-group.sent {
        flex-direction: row-reverse;
    }

    .message-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #cb0c9f, #b00a88);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 14px;
        flex-shrink: 0;
    }

    .message-content {
        max-width: 60%;
    }

    .message-bubble {
        padding: 1rem 1.25rem;
        border-radius: 18px;
        margin-bottom: 0.25rem;
    }

    .message-group.received .message-bubble {
        background: white;
        color: #1f2937;
        border-bottom-left-radius: 4px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .message-group.sent .message-bubble {
        background: linear-gradient(135deg, #cb0c9f, #b00a88);
        color: white;
        border-bottom-right-radius: 4px;
        box-shadow: 0 2px 8px rgba(203, 12, 159, 0.3);
    }

    .message-time {
        font-size: 11px;
        color: #9ca3af;
        padding: 0 0.5rem;
    }

    .message-group.sent .message-time {
        text-align: right;
    }

    .message-status {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        margin-left: 0.5rem;
        color: #3b82f6;
    }

    .date-divider {
        text-align: center;
        margin: 1.5rem 0;
        position: relative;
    }

    .date-divider::before {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        top: 50%;
        height: 1px;
        background: #e5e7eb;
        z-index: 0;
    }

    .date-divider-text {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: #fafafa;
        color: #9ca3af;
        font-size: 12px;
        font-weight: 600;
        border-radius: 20px;
        position: relative;
        z-index: 1;
    }

    /* Input Area */
    .chat-input-area {
        padding: 1.5rem 2rem;
        background: white;
        border-top: 1px solid #f3f4f6;
    }

    .chat-input-container {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
    }

    .chat-input-wrapper {
        flex: 1;
        position: relative;
    }

    .chat-input {
        width: 100%;
        padding: 1rem 3.5rem 1rem 1.25rem;
        border: 2px solid #f3f4f6;
        border-radius: 16px;
        font-size: 15px;
        resize: none;
        max-height: 120px;
        transition: all 0.3s;
    }

    .chat-input:focus {
        outline: none;
        border-color: #cb0c9f;
        background: #fef5fb;
    }

    .chat-input-actions {
        position: absolute;
        right: 0.75rem;
        bottom: 0.75rem;
        display: flex;
        gap: 0.5rem;
    }

    .chat-input-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: none;
        background: transparent;
        color: #9ca3af;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chat-input-btn:hover {
        background: #f3f4f6;
        color: #6b7280;
    }

    .chat-send-btn {
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #cb0c9f, #b00a88);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 16px rgba(203, 12, 159, 0.3);
    }

    .chat-send-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(203, 12, 159, 0.4);
    }

    .chat-send-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* Empty State */
    .chat-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #9ca3af;
    }

    .chat-empty-icon {
        font-size: 64px;
        margin-bottom: 1rem;
    }

    .chat-empty-title {
        font-size: 24px;
        font-weight: 700;
        color: #6b7280;
        margin-bottom: 0.5rem;
    }

    @@media (max-width: 768px) {
        .messages-container {
            grid-template-columns: 1fr;
        }

        .conversations-panel {
            display: none;
        }

        .conversations-panel.mobile-show {
            display: flex;
        }

        .chat-panel.mobile-hide {
            display: none;
        }
    }
</style>

<div class="messages-page">
    <div class="messages-container">
        <!-- Conversations List -->
        <div class="conversations-panel" id="conversationsPanel">
            <div class="conversations-header">
                <h2 class="conversations-title">Messages</h2>
                <div class="conversations-search">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search conversations..." onkeyup="searchConversations(this.value)">
                </div>
            </div>

            <div class="conversations-list" id="conversationsList">
                <!-- Conversation items will be loaded here -->
                <div class="conversation-item active unread" onclick="openConversation(1)">
                    <div class="conversation-header">
                        <div class="conversation-avatar">JS</div>
                        <div class="conversation-info">
                            <div class="conversation-name">
                                <span>John Smith</span>
                                <span class="conversation-time">10:30 AM</span>
                            </div>
                            <div class="conversation-preview">Hi! Is this item still available?</div>
                        </div>
                    </div>
                    <div class="listing-badge">
                        <img src="/Content/uploads/placeholder.jpg" alt="Listing">
                        <div class="listing-badge-info">
                            <div class="listing-badge-title">iPhone 13 Pro Max</div>
                            <div class="listing-badge-price">R 12,500</div>
                        </div>
                    </div>
                </div>

                <div class="conversation-item" onclick="openConversation(2)">
                    <div class="conversation-header">
                        <div class="conversation-avatar">SD</div>
                        <div class="conversation-info">
                            <div class="conversation-name">
                                <span>Sarah Davis</span>
                                <span class="conversation-time">Yesterday</span>
                            </div>
                            <div class="conversation-preview">Thank you! Great seller ??</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chat Panel -->
        <div class="chat-panel" id="chatPanel">
            <!-- Chat Header -->
            <div class="chat-header">
                <div class="chat-user-info">
                    <div class="chat-user-avatar">JS</div>
                    <div class="chat-user-details">
                        <h3>John Smith</h3>
                        <div class="chat-user-status">
                            <span class="status-dot"></span>
                            <span>Active now</span>
                        </div>
                    </div>
                </div>

                <div class="chat-actions">
                    <button class="chat-action-btn" title="View Profile">
                        <i class="fas fa-user"></i>
                    </button>
                    <button class="chat-action-btn" title="View Listing">
                        <i class="fas fa-box"></i>
                    </button>
                    <button class="chat-action-btn" title="More Options">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                </div>
            </div>

            <!-- Messages Area -->
            <div class="chat-messages" id="chatMessages">
                <div class="date-divider">
                    <span class="date-divider-text">Today</span>
                </div>

                <div class="message-group received">
                    <div class="message-avatar">JS</div>
                    <div class="message-content">
                        <div class="message-bubble">
                            Hi! Is this iPhone still available?
                        </div>
                        <div class="message-time">10:30 AM</div>
                    </div>
                </div>

                <div class="message-group sent">
                    <div class="message-avatar">ME</div>
                    <div class="message-content">
                        <div class="message-bubble">
                            Yes, it's still available! Would you like to see it?
                        </div>
                        <div class="message-time">
                            10:32 AM
                            <span class="message-status">
                                <i class="fas fa-check-double"></i>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="message-group received">
                    <div class="message-avatar">JS</div>
                    <div class="message-content">
                        <div class="message-bubble">
                            Perfect! Can we meet tomorrow at 2 PM?
                        </div>
                        <div class="message-time">10:35 AM</div>
                    </div>
                </div>
            </div>

            <!-- Input Area -->
            <div class="chat-input-area">
                <div class="chat-input-container">
                    <div class="chat-input-wrapper">
                        <textarea class="chat-input" 
                                  id="messageInput" 
                                  placeholder="Type your message..." 
                                  rows="1"
                                  onkeypress="handleMessageKeyPress(event)"
                                  oninput="autoResize(this)"></textarea>
                        <div class="chat-input-actions">
                            <button class="chat-input-btn" onclick="attachFile()" title="Attach file">
                                <i class="fas fa-paperclip"></i>
                            </button>
                            <button class="chat-input-btn" onclick="addEmoji()" title="Add emoji">
                                <i class="far fa-smile"></i>
                            </button>
                        </div>
                    </div>
                    <button class="chat-send-btn" id="sendBtn" onclick="sendMessage()">
                        <i class="fas fa-paper-plane mr-2"></i> Send
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function openConversation(id) {
        // Mark as active
        document.querySelectorAll('.conversation-item').forEach(item => item.classList.remove('active'));
        event.currentTarget.classList.add('active');
        event.currentTarget.classList.remove('unread');

        // Load conversation messages
        loadConversation(id);
    }

    function loadConversation(id) {
        // Load messages for the conversation
        console.log('Loading conversation:', id);
    }

    function sendMessage() {
        const input = document.getElementById('messageInput');
        const message = input.value.trim();

        if (!message) return;

        // Add message to chat
        addMessageToChat(message, true);

        // Clear input
        input.value = '';
        input.style.height = 'auto';

        // Send to server
        $.ajax({
            url: '/Home/SendMessage',
            type: 'POST',
            data: {
                receiverId: getCurrentConversationUserId(),
                message: message
            },
            success: function(response) {
                if (response.code === "1") {
                    // Message sent successfully
                    updateMessageStatus('sent');
                } else {
                    showToast(response.message || 'Failed to send message', 'error');
                }
            },
            error: function() {
                showToast('Failed to send message', 'error');
            }
        });
    }

    function addMessageToChat(message, isSent) {
        const messagesContainer = document.getElementById('chatMessages');
        const messageGroup = document.createElement('div');
        messageGroup.className = `message-group ${isSent ? 'sent' : 'received'}`;

        const now = new Date();
        const timeString = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

        messageGroup.innerHTML = `
            <div class="message-avatar">${isSent ? 'ME' : 'JS'}</div>
            <div class="message-content">
                <div class="message-bubble">${message}</div>
                <div class="message-time">${timeString}</div>
            </div>
        `;

        messagesContainer.appendChild(messageGroup);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function handleMessageKeyPress(event) {
        if (event.key === 'Enter' && !event.shiftKey) {
            event.preventDefault();
            sendMessage();
        }
    }

    function autoResize(textarea) {
        textarea.style.height = 'auto';
        textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px';
    }

    function searchConversations(query) {
        // Filter conversations based on search query
        console.log('Searching:', query);
    }

    function attachFile() {
        showToast('File attachment coming soon!', 'info');
    }

    function addEmoji() {
        showToast('Emoji picker coming soon!', 'info');
    }

    function getCurrentConversationUserId() {
        // Get the current active conversation user ID
        return 1;
    }

    function updateMessageStatus(status) {
        // Update message delivery status
        console.log('Message status:', status);
    }

    // Auto-scroll to bottom on load
    $(document).ready(function() {
        const messagesContainer = document.getElementById('chatMessages');
        if (messagesContainer) {
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
    });
</script>
